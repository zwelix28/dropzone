# Copy to .env.local (Vite does NOT read this file — only .env / .env.local / .env.[mode]*)
# Supabase: Project Settings → API — use the project URL + anon (or publishable) key, never service_role.
#
# Netlify: Site configuration → Environment variables — set the same VITE_* names here for production
# previews/branches. Never add SUPABASE_SERVICE_ROLE_KEY or any secret not intended for the browser bundle.

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_or_publishable_key

# Optional: warn/block audio before upload (match Dashboard → Storage → Global file size limit; Free tier max is 50)
# VITE_MAX_AUDIO_MB=50

# Password reset & auth redirects: in Supabase → Authentication → URL Configuration, set Site URL and add
# Redirect URLs: http://localhost:5173/reset-password, https://YOUR-NETLIFY-SITE.netlify.app/reset-password,
# and your custom domain when you add one.

# Audio lockdown: run supabase/lockdown-mix-audio.sql (or use an updated schema.sql) so mix-audio is private,
# mix-previews exists, and mixes.audio_storage_path / audio_preview_path exist. See supabase/lockdown-mix-audio.sql.
